# Copy this file to .env.local (or .env.development.local / .env.production.local)
# and fill in your values. Files matching .env*.local are gitignored.

# Google Analytics 4 Configuration
REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX
REACT_APP_GA_API_SECRET=your_api_secret_here

# AI backend base URL (required for the AI Assistant)
#   Local dev:   put in .env.development.local  -> http://localhost:5221
#   Release:     put in .env.production.local   -> https://your-backend.example.com
REACT_APP_AI_BACKEND_URL=
